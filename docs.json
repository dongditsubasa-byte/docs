{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SunnyMeteo Developer",
  "description": "SunnyMeteo weather, climate, and environmental data developer documentation",
  "colors": {
    "primary": "#3486CF",
    "light": "#74ACDF",
    "dark": "#2A52B8"
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#EEF4FA"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "favicon": "/favicon.svg",
  "seo": {
    "metatags": {
      "canonical": "https://docs.sunnymeteo.com"
    }
  },
  "logo": {
    "light": "/logo/light_sunny.svg",
    "dark": "/logo/dark_sunny.svg",
    "href": "https://www.sunnymeteo.com/zh/"
  },
  "navbar": {
    "links": [
      {
        "label": "官网",
        "href": "https://www.sunnymeteo.com/zh/"
      },
      {
        "label": "Support",
        "href": "mailto:sunnylab2026@yeah.net"
      }
    ]
  },
  "navigation": {
    "languages": [
      {
        "language": "zh",
        "default": true,
        "footer": {
          "socials": {
            "website": "https://www.sunnymeteo.com/zh/"
          }
        },
        "navbar": {
          "links": [
            {
              "label": "官网",
              "href": "https://www.sunnymeteo.com/zh/"
            },
            {
              "label": "支持",
              "href": "mailto:sunnylab2026@yeah.net"
            }
          ]
        },
        "groups": [
          {
            "group": "开发者文档",
            "pages": [
              {
                "group": "引言",
                "expanded": true,
                "pages": ["zh/index", "zh/quickstart"]
              },
              {
                "group": "通用技术说明",
                "expanded": false,
                "pages": [
                  "zh/integrations/api",
                  "zh/integrations/sdk",
                  "zh/integrations/mcp",
                  "zh/integrations/map"
                ]
              },
              {
                "group": "产品",
                "expanded": false,
                "pages": [
                  "zh/products/current-weather",
                  "zh/products/hourly-forecast",
                  "zh/products/daily-forecast",
                  "zh/products/historical-weather",
                  "zh/products/disaster-alerts",
                  "zh/products/air-quality",
                  "zh/products/astronomy",
                  "zh/products/ocean",
                  "zh/products/earthquake",
                  "zh/products/typhoon",
                  "zh/products/climate"
                ]
              },
              {
                "group": "平台",
                "expanded": false,
                "pages": [
                  "zh/platform/map-platform",
                  "zh/platform/solar-meteo-saas",
                  "zh/platform/wind-meteo-saas"
                ]
              },
              {
                "group": "数据字典",
                "expanded": false,
                "pages": [
                  "zh/reference/weather-elements",
                  "zh/reference/units",
                  "zh/reference/coordinate-systems",
                  "zh/reference/location-codes",
                  "zh/reference/status-codes"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "footer": {
          "socials": {
            "website": "https://www.sunnymeteo.com/en/"
          }
        },
        "navbar": {
          "links": [
            {
              "label": "Website",
              "href": "https://www.sunnymeteo.com/en/"
            },
            {
              "label": "Support",
              "href": "mailto:sunnylab2026@yeah.net"
            }
          ]
        },
        "groups": [
          {
            "group": "Documentation",
            "pages": [
              {
                "group": "Introduction",
                "expanded": true,
                "pages": ["en/index", "en/quickstart"]
              },
              {
                "group": "Integrations",
                "expanded": false,
                "pages": [
                  "en/integrations/api",
                  "en/integrations/sdk",
                  "en/integrations/mcp",
                  "en/integrations/map"
                ]
              },
              {
                "group": "Products",
                "expanded": false,
                "pages": [
                  "en/products/current-weather",
                  "en/products/hourly-forecast",
                  "en/products/daily-forecast",
                  "en/products/historical-weather",
                  "en/products/disaster-alerts",
                  "en/products/air-quality",
                  "en/products/astronomy",
                  "en/products/ocean",
                  "en/products/earthquake",
                  "en/products/typhoon",
                  "en/products/climate"
                ]
              },
              {
                "group": "Platform",
                "expanded": false,
                "pages": [
                  "en/platform/map-platform",
                  "en/platform/solar-meteo-saas",
                  "en/platform/wind-meteo-saas"
                ]
              },
              {
                "group": "Reference",
                "expanded": false,
                "pages": [
                  "en/reference/weather-elements",
                  "en/reference/units",
                  "en/reference/coordinate-systems",
                  "en/reference/location-codes",
                  "en/reference/status-codes"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.sunnymeteo.com/zh/"
    }
  }
}
