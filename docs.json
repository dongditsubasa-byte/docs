{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SunnyMeteo Developer",
  "description": "SunnyMeteo weather, climate, and environmental data developer documentation",
  "colors": {
    "primary": "#3486CF",
    "light": "#74ACDF",
    "dark": "#2A52B8"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "官网",
        "href": "https://www.sunnymeteo.com"
      },
      {
        "label": "Support",
        "href": "mailto:sunnylab2026@yeah.net"
      }
    ],
    "primary": {
      "type": "button",
      "label": "API Explorer",
      "href": "https://api.sunnymeteo.com/docs"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Introduction / 引言",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Integrations / 通用技术说明",
        "pages": [
          "integrations/api",
          "integrations/sdk",
          "integrations/mcp",
          "integrations/map"
        ]
      },
      {
        "group": "Products / 产品",
        "pages": [
          "products/current-weather",
          "products/hourly-forecast",
          "products/daily-forecast",
          "products/historical-weather",
          "products/disaster-alerts",
          "products/air-quality",
          "products/astronomy",
          "products/ocean",
          "products/earthquake",
          "products/typhoon",
          "products/climate"
        ]
      },
      {
        "group": "Platform / 平台",
        "pages": [
          "platform/map-platform",
          "platform/solar-meteo-saas",
          "platform/wind-meteo-saas"
        ]
      },
      {
        "group": "Reference / 数据字典",
        "pages": [
          "reference/weather-elements",
          "reference/units",
          "reference/coordinate-systems",
          "reference/location-codes",
          "reference/status-codes"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Explorer",
          "href": "https://api.sunnymeteo.com/docs",
          "icon": "code"
        },
        {
          "anchor": "官网",
          "href": "https://www.sunnymeteo.com",
          "icon": "globe"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.sunnymeteo.com"
    }
  }
}
